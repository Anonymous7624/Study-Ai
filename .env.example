# MongoDB – local default
MONGODB_URI=mongodb://localhost:27017/classpilot

# JWT for session (required; use a strong secret in production)
JWT_SECRET=your-secret-key-change-in-production

# Google OAuth (for Classroom/Drive integration)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Use your public URL when behind Cloudflare/proxy (e.g. https://your-domain.com/api/google/callback)
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# Optional: local uploads directory (default: ./uploads)
# UPLOADS_DIR=./uploads

# Optional: Ollama base URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434
